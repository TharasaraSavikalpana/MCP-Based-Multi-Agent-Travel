# Copy this file to .env for local development.
# Never commit your real .env file.

OPENAI_API_KEY=replace-with-your-openai-key
OPENAI_MODEL=gpt-4o-mini

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=7860
BACKEND_URL=http://127.0.0.1:8000

# MCP servers run as local stdio subprocesses by default.
# For deployment, keep these commands pointed at bundled server files or replace
# them with service-specific commands without changing the core agent graph.
HOTEL_MCP_COMMAND=
FLIGHT_MCP_COMMAND=

APP_ENV=development
